Algoritmo "ex2-encadeada-com"
Const
   MAXMULTIPLICADOR=10
   MAXMULTIPLICADO=20
Var
    multir, multi: inteiro//multir = multiplicador
    //multi = multiplicado
Inicio
   para multir de 1 ate MAXMULTIPLICADOR faca
        para multi de 1 ate MAXMULTIPLICADO faca
escreval(multir,"x",multi,"=",multi*multir)
        fimpara
   fimpara
Fimalgoritmo